<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  macOS-only entitlements for local runs with a free Apple ID.
	  App Sandbox + App Groups let the widget read the app's SwiftData store via the
	  shared group container. App Groups under a free / ad-hoc signature may or may not
	  be honoured by macOS; if it isn't, the menu bar still works and the widget simply
	  falls back to an empty store. No network entitlement — the app is fully local.
	-->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.arronlingham.commit</string>
	</array>
</dict>
</plist>
