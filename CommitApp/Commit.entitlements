<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  iOS entitlements. Intentionally empty so the app signs with a free Apple ID
	  (Personal Team). Outbound network (used by Firestore sync) needs no entitlement
	  on iOS.

	  When you join the paid Apple Developer Program and want native iCloud sync +
	  on-device widget data sharing, add back:
	    com.apple.security.application-groups -> [group.com.arronlingham.commit]
	    com.apple.developer.icloud-container-identifiers -> [iCloud.com.arronlingham.commit]
	    com.apple.developer.icloud-services -> [CloudKit]
	-->
</dict>
</plist>
